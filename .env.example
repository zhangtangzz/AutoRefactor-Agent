# DeepSeek API Key (必填)
ANTHROPIC_API_KEY=sk-your-deepseek-key

# DeepSeek Anthropic 兼容接口地址
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 模型选择 (deepseek-v4-pro / DeepSeek-V3.2)
CLAUDE_MODEL=deepseek-v4-pro

# JWT 密钥 (生产环境请更换为随机字符串)
JWT_SECRET=your-random-secret-here-change-in-production
JWT_EXPIRE_MINUTES=60

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ChromaDB 持久化目录
CHROMA_PERSIST_DIR=./data/chroma

# 文档分块设置
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# 对话设置
MAX_CONVERSATION_TURNS=5
CONVERSATION_TTL=3600

# 检索返回数量
TOP_K_RETRIEVAL=5

# 调试模式
DEBUG=false

# 上传目录
UPLOAD_DIR=./uploads
